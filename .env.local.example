# Copy this file to .env.local and fill in your values.

# Sender login credentials (REQUIRED — login form won't work without these)
AUTH_USERNAME=OrionLiveWebCam
AUTH_PASSWORD=W33e8>$74tH

# Secret used to sign 7-day JWTs — set to any long random string
JWT_SECRET=replace-with-a-long-random-secret

# REQUIRED on Vercel (or any serverless/multi-instance host) — fixes the viewer
# PIN so every serverless function instance agrees on the same value instead of
# each generating its own. Pick any 6-digit number.
# STREAM_PIN=123456

# DuckDNS + coturn configuration for remote WebRTC
# Without these, the app still works on LAN using Google STUN only.

# Your DuckDNS subdomain hostname (e.g. mystream.duckdns.org)
NEXT_PUBLIC_TURN_HOST=yourname.duckdns.org

# coturn listening port (default 3478)
NEXT_PUBLIC_TURN_PORT=3478

# Must match the --user= value you set when running coturn
NEXT_PUBLIC_TURN_USER=webrtc
NEXT_PUBLIC_TURN_PASS=changeme
